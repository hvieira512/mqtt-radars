# MQTT Broker Connection
MQTT_SERVER=your_mqtt_server_ip
MQTT_PORT=1883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
MQTT_CLIENT_ID=php-radar-router-local
MQTT_TOPIC=radar/frontend

# Database Connection
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=radar
DB_USERNAME=radar_user
DB_PASSWORD=your_db_password

# HobaCare API Credentials (for sleep reports)
APP_ID=your_app_id
SECRET=your_app_secret
HOBACARE_USERNAME=your_hobacare_username
HOBACARE_PASSWORD=your_hobacare_password
BASE_URL=https://api.hobacare.com

# Redis
REDIS_URL=tcp://127.0.0.1:6379

# CRM URL for tenant URL lookup
CRM_URL=https://crm.hitcare.net/api/get.url.php
CRM_CACHE_TTL=3600

# Tenant forward consumers
FORWARD_SLEEP_MS=50
FORWARD_CONNECT_TIMEOUT_MS=750
FORWARD_TIMEOUT_MS=5000
FORWARD_MAX_ATTEMPTS=3
FORWARD_DRY_RUN=false
# Optional: pin one consumer to one license, e.g. 1001
FORWARD_LICENSE=
# Optional: for generic consumers, skip dedicated licenses, e.g. 1001,2103
FORWARD_EXCLUDE_LICENSES=
